# the-gitfather profile for liveone — NON-SECRET config for the off-site Postgres → R2 backups.
#
# Credentials (PG_BACKUP_DATABASE_URL, R2_*, SLACK_BOT_TOKEN, HEARTBEAT_URL, ALERT_WEBHOOK_URL,
# DASHBOARD_R2_*) come from GitHub secrets/vars via the caller workflows in .github/workflows/pg-*.yml
# — never from here. Engine + reference: https://github.com/simonhac/the-gitfather

# Object-key layout: <BACKUP_PREFIX>/<tier>/<FILE_BASENAME>-<stamp>.<ext>
# Keep liveone's existing layout so new .dump objects coexist with the legacy .dump.gz until they age out.
BACKUP_PREFIX="pg/sydney"
FILE_BASENAME="liveone"

# Full custom-format dump, restorable into a vanilla Postgres. Exclude the PlanetScale-managed schema
# so a provider-loss restore is clean (matches the Sydney cutover + the previous backup script). No
# gzip: -Fc is already zlib-compressed and the toolkit uploads the raw .dump.
PG_DUMP_FLAGS="-Fc --no-owner --no-privileges --exclude-schema=pscale_extensions"

ENCRYPTION="none"            # liveone does not set AGE_RECIPIENT; dumps sit in a private (R2-encrypted) bucket
PG_CLIENT_MAJOR="17"         # Sydney runs PG 17.10 — the dump client must be >= the server

# GFS (UTC): every run → 2hourly/; the run at ANCHOR_HOUR_UTC promotes to daily/ (+weekly on Sun,
# +monthly on the 1st). 16:00 UTC ≈ 02:00 Sydney, preserving the old ~02:17 Sydney daily anchor.
ANCHOR_HOUR_UTC="16"

# Restore drill: sentinel must restore to ≥ MIN_RATIO × live (n_live_tup estimate); extras just non-empty.
DRILL_SENTINEL_TABLE="point_readings"
DRILL_EXTRA_TABLES="sessions point_readings_agg_5m"
MIN_RATIO="0.95"

MIN_BYTES="104857600"        # 100 MB floor — keep liveone's existing sanity gate (toolkit default is 1 MB)
STALE_HOURS="5"              # alert if no fresh 2hourly object in 5 h

DISPLAY_TZ="Australia/Sydney"   # Slack daily-row + dashboard heatmap rendering timezone
SLACK_ALERT_MENTION="<!here>"
DASHBOARD_LABEL="liveone"
