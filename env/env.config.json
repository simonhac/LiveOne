{
  "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY": {
    "required": true,
    "sensitive": false,
    "description": "Clerk publishable key (pk_test_* or pk_live_*)"
  },
  "CLERK_SECRET_KEY": {
    "required": true,
    "sensitive": true,
    "description": "Clerk secret key (sk_test_* or sk_live_*)"
  },
  "DATABASE_URL": {
    "required": false,
    "sensitive": false,
    "default": "file:./dev.db",
    "description": "SQLite URL for local dev"
  },
  "CRON_SECRET": {
    "required": "production",
    "sensitive": true,
    "description": "Bearer secret for /api/cron/* endpoints"
  },
  "NEXT_PUBLIC_CLERK_SIGN_IN_URL": {
    "required": false,
    "sensitive": false,
    "default": "/sign-in",
    "description": "Clerk sign-in route"
  },
  "NEXT_PUBLIC_CLERK_SIGN_UP_URL": {
    "required": false,
    "sensitive": false,
    "default": "/sign-up",
    "description": "Clerk sign-up route"
  },
  "NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL": {
    "required": false,
    "sensitive": false,
    "default": "/dashboard",
    "description": "Post-sign-in redirect"
  },
  "NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL": {
    "required": false,
    "sensitive": false,
    "default": "/setup",
    "description": "Post-sign-up redirect"
  },
  "KV_REST_API_URL": {
    "required": false,
    "sensitive": false,
    "description": "Vercel KV REST URL (cache for latest point values)"
  },
  "KV_REST_API_TOKEN": {
    "required": false,
    "sensitive": true,
    "description": "Vercel KV REST token"
  },
  "ADMIN_USER_IDS": {
    "required": false,
    "sensitive": false,
    "description": "Comma-separated Clerk user IDs granted admin role"
  },
  "QSTASH_TOKEN": {
    "required": false,
    "sensitive": true,
    "description": "Upstash QStash token for the observations queue"
  },
  "QSTASH_CURRENT_SIGNING_KEY": {
    "required": false,
    "sensitive": true,
    "description": "QStash current signing key (verifies inbound webhooks)"
  },
  "QSTASH_NEXT_SIGNING_KEY": {
    "required": false,
    "sensitive": true,
    "description": "QStash next signing key (verifies inbound webhooks)"
  }
}
