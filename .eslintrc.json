{
  "extends": "next/core-web-vitals",
  "rules": {
    "no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "@/lib/db/planetscale/schema",
            "importNames": [
              "pointReadings",
              "pointReadingsAgg5m",
              "pointReadingsAgg1d",
              "PointReading",
              "NewPointReading",
              "PointReadingAgg5m",
              "NewPointReadingAgg5m",
              "PointReadingAgg1d",
              "NewPointReadingAgg1d"
            ],
            "message": "Hot time-series tables are behind the readings DAO (config-v4 Phase 3). Import ReadingsDao from '@/lib/readings' instead. Authoritative gate: scripts/check-readings-boundary.mjs."
          }
        ],
        "patterns": [
          {
            "group": ["**/db/planetscale/schema", "./schema", "../**/schema"],
            "importNames": [
              "pointReadings",
              "pointReadingsAgg5m",
              "pointReadingsAgg1d",
              "PointReading",
              "NewPointReading",
              "PointReadingAgg5m",
              "NewPointReadingAgg5m",
              "PointReadingAgg1d",
              "NewPointReadingAgg1d"
            ],
            "message": "Hot time-series tables are behind the readings DAO (config-v4 Phase 3). Relative import of a hot-table symbol is banned outside lib/readings/** + lib/registry/**."
          }
        ]
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "lib/readings/**",
        "lib/registry/**",
        "lib/db/planetscale/index.ts",
        "**/__tests__/**"
      ],
      "rules": { "no-restricted-imports": "off" }
    }
  ]
}
