{
  "regions": ["syd1"],
  "crons": [
    {
      "path": "/api/cron/minutely",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/daily",
      "schedule": "5 14 * * *"
    },
    {
      "path": "/api/cron/db-stats",
      "schedule": "0 2,14 * * *"
    },
    {
      "path": "/api/cron/monitor-observations",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/relay-outbox",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/run-periods",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/repair-coverage",
      "schedule": "30 15 * * 1"
    }
  ],
  "functions": {
    "app/api/cron/run-periods/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/minutely/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/relay-outbox/route.ts": {
      "maxDuration": 60
    },
    "app/api/cron/db-stats/route.ts": {
      "maxDuration": 180
    },
    "app/api/history/route.ts": {
      "maxDuration": 30
    },
    "app/api/cron/repair-coverage/route.ts": {
      "maxDuration": 300
    }
  }
}
